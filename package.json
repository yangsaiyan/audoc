{
  "name": "audoc",
  "displayName": "Audoc",
  "description": "",
  "version": "0.0.1",
  "publisher": "Audoc",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "audoc",
          "title": "Audoc",
          "icon": "media/audoc.svg"
        }
      ]
    },
    "views": {
      "audoc": [
        {
          "icon": "media/audoc.svg",
          "id": "audocView",
          "name": "Audoc",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "audoc.generateDocumentation",
        "title": "Generate Documentation"
      },
      {
        "command": "audoc.setApiKey",
        "title": "Set API Key"
      },
      {
        "command": "audoc.clearApiKey",
        "title": "Clear API Key"
      },
      {
        "command": "audoc.selectModel",
        "title": "Select Model for Current AI Provider"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "audoc.generateDocumentation",
          "when": "editorTextFocus"
        }
      ]
    },
    "configuration": {
      "title": "Audoc AI Settings",
      "properties": {
        "audoc.uiLanguage": {
          "order": 0,
          "type": "string",
          "enum": [
            "en",
            "zh-tw"
          ],
          "default": "en",
          "description": "Language for Audoc UI (notifications and sidebar). Does not follow VS Code display language.",
          "enumDescriptions": [
            "English",
            "Traditional Chinese (Taiwan)"
          ]
        },
        "audoc.documentationLanguage": {
          "order": 1,
          "type": "string",
          "enum": [],
          "default": "",
          "description": "Select the language for the documentation."
        },
        "audoc.aiProvider": {
          "order": 2,
          "type": "string",
          "enum": [],
          "default": "",
          "description": "Select the AI provider to use for generating documentation."
        },
        "audoc.geminiModel": {
          "order": 3,
          "type": "string",
          "enum": [],
          "default": "",
          "description": "Model to use when AI Provider is Google Gemini."
        },
        "audoc.chatgptModel": {
          "order": 4,
          "type": "string",
          "enum": [],
          "default": "",
          "description": "Model to use when AI Provider is ChatGPT."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "yarn run compile && yarn run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.43.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "openai": "^6.27.0"
  }
}
